---
export interface Props {
  title?: string;
  controls: { key: string; description: string }[];
}
const { title, controls } = Astro.props;
---
<div class="controls-table reveal-on-scroll">
  {title && <h3>{title}</h3>}
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Key</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {controls.map((ctrl) => (
          <tr>
            <td class="key-cell"><kbd>{ctrl.key}</kbd></td>
            <td>{ctrl.description}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
.controls-table {
  margin: 2em auto;
  max-width: 100%;
}

.controls-table h3 {
  margin-bottom: 1rem;
  color: var(--sl-color-white);
  font-size: 1.25rem;
  letter-spacing: -0.01em;
}

.table-wrapper {
  overflow-x: auto;
  border-radius: 0.75rem;
  border: 1px solid hsl(var(--border) / 0.5);
  background: linear-gradient(to bottom right, hsl(var(--muted-foreground) / 0.05), transparent);
  box-shadow: var(--shadow-sm);
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.95rem;
  min-width: 400px;
}

thead {
  background: hsl(var(--secondary) / 0.8);
  border-bottom: 1px solid hsl(var(--border));
}

th {
  padding: 0.85rem 1.25rem;
  text-align: left;
  font-weight: 600;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--sl-color-text-accent);
}

td {
  padding: 0.85rem 1.25rem;
  text-align: left;
  border-bottom: 1px solid hsl(var(--border) / 0.3);
  color: var(--sl-color-text);
}

tbody tr:last-child td {
  border-bottom: none;
}

tbody tr {
  transition: background-color 0.2s ease;
}

tbody tr:hover {
  background: hsl(var(--primary) / 0.05);
}

.key-cell {
  white-space: nowrap;
  width: 30%;
}

.key-cell kbd {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: hsl(var(--background));
  border: 1px solid hsl(var(--border));
  border-bottom-width: 2px;
  padding: 0.25em 0.6em;
  border-radius: 0.35em;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 0.85em;
  font-weight: 600;
  color: var(--sl-color-white);
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  min-width: 2em;
}
</style>
